# Required — get one at https://platform.openai.com
OPENAI_API_KEY=

# Optional — vision model for label extraction (default: gpt-5.4-mini).
# Measured live, mini reads real-label fine print reliably AND faster than
# gpt-5.4-nano, which misreads the government warning (and is cheaper but
# not actually quicker here).
# OPENAI_MODEL=gpt-5.4-mini

# Optional — reasoning effort for the extraction call (default: none, the
# fastest; set to low for model tiers that don't accept none, e.g. gpt-5.5).
# OPENAI_REASONING_EFFORT=none
