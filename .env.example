# Required — get one at https://platform.openai.com
OPENAI_API_KEY=

# Required — vision model for label extraction. There is no default and no
# fallback: the app refuses to verify until this is set. Mind the ~5s/label
# budget; mini-class models read real-label fine print reliably, nano-class
# misreads the government warning (measured live on the 5.4 tier).
OPENAI_MODEL=gpt-5-mini

# Optional — reasoning effort for the extraction call. Unset = the API's
# own default for the model. Valid values are tier-specific: "minimal" is
# gpt-5's floor, "none" exists from gpt-5.1, gpt-5.5 bottoms out at "low".
# Transcription needs no deliberation — the lowest accepted value is
# usually right.
# OPENAI_REASONING_EFFORT=minimal
